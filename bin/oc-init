#!/bin/bash
# oc-init: Initializes a project with the Opencode/Claude Harness framework.

set -e

# --- Help Section ---
if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
    echo "Usage: oc-init <template_name>"
    echo ""
    echo "Initializes the current directory with the AI Multi-Agent Harness framework."
    echo "This creates a .claude/ directory and copies the appropriate OPENCODE.md"
    echo "and run-checks.sh templates into it, ensuring clean project roots."
    echo ""
    echo "Available templates:"
    echo "  python  - Enforces ruff linting and pytest"
    echo "  web     - Enforces package.json, eslint, and npm test"
    echo "  c_cpp   - Enforces make/cmake and clang-tidy"
    echo "  go      - Enforces go fmt, vet, staticcheck, and go test"
    echo "  generic - A blank slate. Use this for unknown languages/frameworks."
    echo ""
    echo "Example:"
    echo "  oc-init web"
    exit 0
fi

HARNESS_DIR="$HOME/linux_workflow/opencode-harness/templates"
HOOK_TEMPLATE="#!/bin/bash\n\n# Opencode Pre-push Hook (Garbage Collection)\n# This triggers the garbage collector before code is pushed to remote.\n\necho \"Running Opencode Garbage Collection...\"\noc-gc || {\n  echo \"Garbage collection failed or found issues that need manual review.\"\n  echo \"Push aborted. You can bypass this with git push --no-verify\"\n  exit 1\n}\n\nexit 0\n"

if [ $# -ne 1 ]; then
    echo "Usage: oc-init <template_name>"
    echo "Run 'oc-init --help' for more information."
    exit 1
fi

TEMPLATE=$1

if [ ! -d "$HARNESS_DIR/$TEMPLATE" ]; then
    echo "Error: Template '$TEMPLATE' not found in $HARNESS_DIR"
    exit 1
fi

echo "Initializing AI harness using template '$TEMPLATE'..."

# Create the .claude directory to keep the project root clean
mkdir -p .claude

# Copy templates into the .claude directory
cp "$HARNESS_DIR/$TEMPLATE/OPENCODE.md" .claude/
cp "$HARNESS_DIR/$TEMPLATE/run-checks.sh" .claude/

chmod +x .claude/run-checks.sh

# Setup git hook if it's a git repo
if [ -d ".git" ]; then
    HOOK_DIR=".git/hooks"
    PRE_PUSH="$HOOK_DIR/pre-push"
    
    echo -e "$HOOK_TEMPLATE" > "$PRE_PUSH"
    chmod +x "$PRE_PUSH"
    echo "Installed git pre-push hook for automatic garbage collection."
else
    echo "Not a git repository. Skipping pre-push hook installation."
fi

echo "Initialization complete! Files stored in .claude/"
echo "Please review .claude/OPENCODE.md and customize .claude/run-checks.sh as needed."
