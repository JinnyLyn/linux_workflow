#!/bin/bash
# oc-gc: Manual garbage collection script.

# --- Help Section ---
if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
    echo "Usage: oc-gc"
    echo ""
    echo "Triggers a manual Garbage Collection pass using the 'code-gc' agent."
    echo "This is automatically run by the pre-push hook (if installed via oc-init),"
    echo "but can be run manually at any time."
    echo ""
    echo "The agent will:"
    echo "  1. Read .claude/OPENCODE.md rules."
    echo "  2. Scan the project for dead code, unused imports, and commented-out blocks."
    echo "  3. Remove the garbage."
    echo "  4. Ensure .claude/run-checks.sh still passes."
    echo "  5. Commit the cleanups automatically."
    exit 0
fi

# --- Execution Section ---
MODIFIED_FILES=$(git status --porcelain | awk '{print $2}')

if [ -z "$MODIFIED_FILES" ]; then
    echo "No modified files detected. Skipping Garbage Collection."
    exit 0
fi

echo "Triggering AI Garbage Collection on modified files..."
echo "Files to check: $MODIFIED_FILES"

PROMPT="Please use the Task tool to launch the 'code-gc' subagent to perform a targeted Garbage Collection pass on the following modified files:
$MODIFIED_FILES

Process:
1. Read .claude/OPENCODE.md to understand the current rules.
2. Scan ONLY the files listed above for violations (dead code, unused imports, commented-out blocks).
3. Remove the garbage and ensure the files follow project standards.
4. Run '.claude/run-checks.sh' to ensure your cleanup did not break anything.
5. If changes were made and tests pass, commit the changes with a message like 'chore: AI garbage collection cleanup (modified files)'.
"

opencode run "$PROMPT"
